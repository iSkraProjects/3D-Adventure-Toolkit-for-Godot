[sub_resource type="Resource" id="Res_greet"]
script = ExtResource("2_node")
node_id = "greet"
speaker_name = "Curator"
text = "Dialogue can run actions when a line finishes. Press Continue."
next_node_id = "give_key"

[sub_resource type="Resource" id="Res_unique_gate"]
script = ExtResource("5_cond")
item_id = "item_brass_key"
condition_id = "dlg_brass_key_still_obtainable"

[sub_resource type="Resource" id="Res_add_key"]
script = ExtResource("4_add")
item_id = "item_brass_key"
step_id = "dialogue_give_brass_key"

[sub_resource type="Resource" id="Res_seq_leave"]
script = ExtResource("3_seq")
sequence_id = "dlg_give_key_on_leave"
steps = Array[ExtResource("5_sfsst")]([SubResource("Res_add_key")])

[sub_resource type="Resource" id="Res_give_key"]
script = ExtResource("2_node")
node_id = "give_key"
speaker_name = "Curator"
text = "Here is a brass key (same item_id as the world pickup). Check your inventory after Continue."
entry_conditions = SubResource("Res_unique_gate")
fallback_next_node_id = "thanks_done"
on_leave_actions = SubResource("Res_seq_leave")
ends_dialogue = true

[sub_resource type="Resource" id="Res_thanks"]
script = ExtResource("2_node")
node_id = "thanks_done"
speaker_name = "Curator"
text = "Thank you. You already have the brass key — put it to good use."
ends_dialogue = true

[resource]
script = ExtResource("1_def")
dialogue_id = "dlg_test_gives_key"
start_node_id = "greet"
nodes = Array[ExtResource("2_node")]([SubResource("Res_greet"), SubResource("Res_give_key"), SubResource("Res_thanks")])
