[ext_resource type="Script" uid="uid://c06xfway4ukgi" path="res://addons/adventure_toolkit/resources/dialogue/atk_dialogue_node.gd" id="2_node"]
[ext_resource type="Script" uid="uid://b2102xfjhdoip" path="res://addons/adventure_toolkit/resources/dialogue/atk_dialogue_choice.gd" id="2_oowwc"]
[ext_resource type="Script" uid="uid://bw36dkwk3v8ul" path="res://addons/adventure_toolkit/resources/actions/atk_action_sequence.gd" id="3_seq"]
[ext_resource type="Script" uid="uid://b5u3p7gnjkegq" path="res://addons/adventure_toolkit/resources/actions/atk_action_step_add_item.gd" id="4_add"]
