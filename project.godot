; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AGToolkit"
run/main_scene="res://addons/adventure_toolkit/demo/sample_game/scenes/atk_main_menu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

ATKScenes="*uid://coyew76k76msx"
ATKState="*uid://d08b4x03ws3df"
ATKSave="*uid://fhx1ytiootg0"
ATKInventory="*uid://cfbulrj26eanq"
ATKQuests="*res://addons/adventure_toolkit/runtime/autoload/atk_quests.gd"
ATKJournal="*res://addons/adventure_toolkit/runtime/autoload/atk_journal.gd"
ATKHints="*res://addons/adventure_toolkit/runtime/autoload/atk_hints.gd"
