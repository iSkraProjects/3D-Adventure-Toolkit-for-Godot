ATKAudio="*res://addons/adventure_toolkit/runtime/autoload/atk_audio.gd"
ATKCutscenes="*uid://bnd7b220mw38y"
ATKSettings="*res://addons/adventure_toolkit/runtime/autoload/atk_settings.gd"
ATKEpisodes="*res://addons/adventure_toolkit/runtime/autoload/atk_episodes.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/adventure_toolkit/plugin.cfg")

